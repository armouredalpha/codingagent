.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.tox/

# IDE / Editor
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
*.iml
*.sublime-*

# OS
.AppleDouble
.LSOverride
.DS_Store

# Package builds
*.whl
*.tar.gz
dist/
build/

# Old logs (should be ignored)
*.log
run_all.log

# Keep examples
!.env.example
!logs/.gitkeep
!memory/.gitkeep
!vectorstore/.gitkeep
!outputs/.gitkeep
!reports/.gitkeep
!eval/.gitkeep
