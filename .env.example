# Copy to `.env` and fill in your API key.
# Two providers are supported: openrouter or anthropic.

# Provider: openrouter | anthropic
ROBO_PROVIDER=openrouter

# Model id (provider-specific). Examples:
#   openrouter : openai/gpt-4o, anthropic/claude-sonnet-4-6, openai/gpt-4o-mini
#   anthropic  : claude-haiku-4-5-20251001, claude-sonnet-4-6
ROBO_MODEL=openai/gpt-4o

# API Keys — set the one matching your provider:
# OPENROUTER_API_KEY=sk-or-...   ← OpenRouter
# ANTHROPIC_API_KEY=sk-ant-...   ← Anthropic Claude

# Optional overrides
# ROBO_NUM_QUESTIONS=6
# ROBO_LOG_LEVEL=INFO
